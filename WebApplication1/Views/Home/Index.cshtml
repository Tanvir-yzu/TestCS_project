@{
    ViewData["Title"] = "AmosWRN — Weather Forecast";
    var products = ViewData["Products"] as IEnumerable<WebApplication1.Models.Product> ?? Enumerable.Empty<WebApplication1.Models.Product>();
}

<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-md-7">
            <h1 class="display-4">AmosWRN</h1>
            <p class="lead text-muted">Intelligent, reliable weather forecasts powered by the AmosWRN model. Get timely updates, alerts, and a clear 7-day outlook for your location.</p>

            <p>
                <a class="btn btn-primary btn-lg me-2" href="#forecast" role="button">See 7-day Forecast</a>
                <a class="btn btn-outline-secondary btn-lg" href="#features" role="button">How it works</a>
            </p>

            <ul class="list-unstyled text-muted mt-4">
                <li>• High-accuracy short and medium range forecasts</li>
                <li>• Real-time alerts for severe weather</li>
                <li>• Lightweight API and embeddable widgets</li>
            </ul>
        </div>
        <div class="col-md-5 text-center d-none d-md-block">
            <div class="card shadow-sm" style="max-width:320px; margin:auto;">
                <div class="card-body">
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        var username = User.Identity?.Name;
                        var u = products.SelectMany(p => new[] { p }).FirstOrDefault(); // no-op to keep Razor happy
                        <div class="d-flex align-items-center gap-3">
                            <div>
                                @{ 
                                    var userRepo = Context.RequestServices.GetService(typeof(WebApplication1.Data.IUserRepository)) as WebApplication1.Data.IUserRepository;
                                    var usr = userRepo?.GetByUsername(username ?? string.Empty);
                                }
                                @if (usr != null && !string.IsNullOrWhiteSpace(usr.AvatarPath))
                                {
                                    <img src="@usr.AvatarPath" style="width:96px; height:96px; object-fit:cover; border-radius:8px;" />
                                }
                                else
                                {
                                    <div style="width:96px; height:96px; background:#eee; display:flex; align-items:center; justify-content:center; border-radius:8px;">No avatar</div>
                                }
                            </div>
                            <div class="text-start">
                                <h5 class="mb-0">@username</h5>
                                <div class="text-muted">@if (usr != null) { @usr.Email }</div>
                                <div class="mt-2"><a class="btn btn-sm btn-outline-primary" asp-controller="Account" asp-action="Profile">Profile</a></div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <h5 class="card-title">Welcome</h5>
                        <p class="text-muted">Sign in to manage products and your profile.</p>
                        <div><a class="btn btn-primary" asp-controller="Account" asp-action="Login">Sign in</a></div>
                    }
                </div>
            </div>
        </div>
    </div>

    <section id="features" class="mt-5">
        <h3>Features</h3>
        <div class="row g-4 mt-3">
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">High Accuracy</h5>
                        <p class="card-text text-muted">AmosWRN blends observational data and model ensembles to deliver robust forecasts across time ranges.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Alerts & Notifications</h5>
                        <p class="card-text text-muted">Subscribe to receive push and email alerts for severe weather in your area.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Embeddable Widgets</h5>
                        <p class="card-text text-muted">Lightweight widgets make it easy to add forecasts to any site or dashboard.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section id="add-product" class="mt-5">
        <h3>Add product</h3>

        @if (User?.Identity?.IsAuthenticated == true)
        {
            <div class="card mt-3 p-3">
                <form method="post" asp-controller="Home" asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                    <div class="row g-2">
                        <div class="col-md-4">
                            <input class="form-control" name="name" placeholder="Product name" />
                        </div>
                        <div class="col-md-4">
                            <input class="form-control" name="price" type="number" step="0.01" placeholder="Price" />
                        </div>
                        <div class="col-md-4">
                            <input class="form-control" name="images" type="file" multiple />
                        </div>
                        <div class="col-12 mt-2">
                            <textarea class="form-control" name="description" placeholder="Short description"></textarea>
                        </div>
                        <div class="col-12 mt-2">
                            <button class="btn btn-success" type="submit">Add product</button>
                        </div>
                    </div>
                </form>
            </div>
        }
        else
        {
            <p class="text-muted">You must <a asp-controller="Account" asp-action="Login">sign in</a> to add products.</p>
        }
    </section>

    <section id="featured-products" class="mt-5">
        <h3>Featured products</h3>
        <div class="row g-3 mt-3">
            @{
                var featured = products.Take(4).ToList();
            }

            @if (!featured.Any())
            {
                <div class="col-12">
                    <p class="text-muted">No featured products yet. Add a product to get started.</p>
                </div>
            }
            else
            {
                @foreach (var p in featured)
                {
                    <div class="col-6 col-md-3">
                        <div class="card h-100">
                            @if (p.ImagePaths != null && p.ImagePaths.Count > 0)
                            {
                                <img src="@p.ImagePaths.First()" class="card-img-top product-image" />
                            }
                            <div class="card-body">
                                <h5 class="card-title">@p.Name</h5>
                                <p class="card-text text-muted">@p.Description</p>
                                <div class="fw-bold">@p.Price.ToString("C")</div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
    <section id="products" class="mt-5">
    <h3>Products</h3>

    @if (!products.Any())
    {
        <p class="text-muted">
            No products available. 
            @if (!(User?.Identity?.IsAuthenticated == true))
            {
                @:<a asp-controller="Account" asp-action="Login">Sign in</a> to add products.
            }
        </p>
    }
    else
    {
        <div class="row g-3 mt-3">
            @foreach (var p in products)
            {
                <div class="col-6 col-md-3">
                    <div class="card h-100">
                        <div class="card-body">
                            @if (p.ImagePaths != null && p.ImagePaths.Count > 0)
                            {
                                <div class="mb-2 text-center">
                                    <img src="@p.ImagePaths.First()" class="product-thumb" />
                                </div>
                            }
                            <h5 class="card-title">@p.Name</h5>
                            <p class="card-text text-muted">@p.Description</p>
                            <div class="fw-bold">@p.Price.ToString("C")</div>
                            @if (User?.Identity?.IsAuthenticated == true)
                            {
                                <div class="mt-2">
                                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@p.Id">Edit</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

    <footer class="mt-5 text-center text-muted">
        <small>© @DateTime.Now.Year AmosWRN — Weather Forecast. Data provided for demonstration purposes.</small>
    </footer>
</div>
