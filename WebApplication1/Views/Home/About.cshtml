@{
    ViewData["Title"] = "About AmosWRN";
}

<div class="container py-5">
    <h1 class="mb-3">About AmosWRN</h1>
    <p class="lead text-muted">AmosWRN provides trusted weather forecasts and alerts powered by modern forecasting models and observational data.</p>

    <h3 class="mt-4">Our Mission</h3>
    <p>We aim to deliver accurate, accessible, and timely weather information to help people make better decisions—whether they're planning a trip or preparing for severe weather.</p>

    <h3 class="mt-4">What we do</h3>
    <ul>
        <li>Short and medium-range weather forecasts</li>
        <li>Localized severe weather alerts</li>
        <li>APIs and embeddable widgets for developers</li>
    </ul>

    <h3 class="mt-4">Team</h3>
    <p>AmosWRN is developed by a team of meteorologists, data scientists, and engineers focused on building reliable weather services.</p>

    <h3 class="mt-4">Contact</h3>
    <p>If you'd like to learn more, reach out at <a href="mailto:info@amoswrn.example">info@amoswrn.example</a>.</p>
</div>
